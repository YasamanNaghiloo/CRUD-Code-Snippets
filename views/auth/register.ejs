<!DOCTYPE html>
<html>
<head>
  <title>Register</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<h1>Register</h1>

<form action="/register" method="post" class="auth-form">
  <label>Username</label>
